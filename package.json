{
  "name": "ctf-writeup-hub",
  "type": "module",
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=7.0.0",
    "npm": "please use pnpm"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "check": "pnpm -r --if-present run check",
    "fix": "pnpm -r --if-present run fix",
    "dev:backend": "cd src/backend && python -m uvicorn app.main:app --reload --port 8000",
    "dev:frontend": "cd src/frontend && pnpm dev"
  },
  "devDependencies": {}
}
